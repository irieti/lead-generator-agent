# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-opus-4-5

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_APPROVAL_TIMEOUT=300   # seconds to wait for approval before skipping

# Gmail OAuth
GMAIL_CREDENTIALS_JSON=./gmail_credentials.json   # OAuth2 client credentials
GMAIL_TOKEN_JSON=./gmail_token.json               # auto-generated after first auth

# Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_JSON=./service_account.json

# LinkedIn (Playwright)
LINKEDIN_EMAIL=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password
LINKEDIN_HEADLESS=true
LINKEDIN_DAILY_INVITE_LIMIT=10    # safety cap
LINKEDIN_DELAY_BETWEEN_ACTIONS=3  # seconds

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# LinkedIn API (for posting via official API)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/callback
LINKEDIN_ACCESS_TOKEN=your_access_token   # generated after OAuth flow
